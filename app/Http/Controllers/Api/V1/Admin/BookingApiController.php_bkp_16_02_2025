        ]);

        if ($validator->fails()) {
            return $this->errorComputing($validator);
        }

        $limit = $request->input('limit', 10);
        $offset = $request->input('offset', 0);

        $user_id = $this->checkUserByToken($request->token);
        if (!$user_id) {
            return $this->addErrorResponse(419, trans('front.token_not_match'), '');
        }

        $upcomingType = $request->type;
        $module = $this->getModuleIdOrDefault($request);

        $bookingsQuery = Booking::where('host_id', $user_id)
            ->whereIn('payment_status', ['paid'])
            ->where('module', $module)
            ->leftJoin('booking_extensions', 'bookings.id', '=', 'booking_extensions.booking_id')
            ->leftJoin('booking_finance', 'bookings.id', '=', 'booking_finance.booking_id')
            ->select(
                'bookings.*',
                'booking_extensions.drop_otp',
                'booking_extensions.pick_otp',
                'booking_extensions.is_item_delivered',
                'booking_extensions.is_item_received',
                'booking_extensions.is_item_returned',
                'booking_extensions.doorStep_address',
                'booking_extensions.doorStep_price',
                'booking_finance.total_day',
                'booking_finance.per_day',
                'booking_finance.base_price',
                'booking_finance.doorstep_price',
                'booking_finance.security_money',
                'booking_finance.iva_tax',
                'booking_finance.coupon_code',
                'booking_finance.coupon_discount',
                'booking_finance.discount_price',
                'booking_finance.cancelled_charge'
            );

        $nowDate = DateFormat::toDateString(Carbon::now());
        $nowTime = Carbon::now('Asia/Kolkata')->format('H:i:s');

        switch ($upcomingType) {
            case 'upcoming':
                $bookings = $bookingsQuery
                    ->whereDate('check_in', '>=', Carbon::now()->toDateString())
                    ->whereNotIn('status', ['Cancelled', 'Declined', 'Completed'])
                    ->where(function ($query) {
                        $query->whereNull('booking_extensions.is_item_received')
                            ->orWhere('booking_extensions.is_item_received', '!=', 1);
                    });
                $responseKey = 'vendor_upcoming_bookings_is';
                break;

            case 'ongoing':
                $bookings = $bookingsQuery
                    ->whereNotIn('status', ['Cancelled', 'Declined', 'Completed'])
                    ->where('booking_extensions.is_item_received', 1);
                $responseKey = 'vendor_ongoing_bookings_is';
                break;

            case 'Cancelled':
                $bookings = $bookingsQuery
                    ->whereIn('status', ['Cancelled', 'Declined']);
                $responseKey = 'vendor_upcoming_bookings_is';
                break;

            case 'previous':
                $bookings = $bookingsQuery->where(function ($query) use ($nowDate, $nowTime) {
                    $query->where('check_out', '<', $nowDate)
                        ->orWhere(function ($subQuery) use ($nowDate, $nowTime) {
                            $subQuery->whereDate('check_out', '=', $nowDate)
                                ->whereRaw("STR_TO_DATE(end_time, '%h:%i %p') <= ?", [$nowTime]);
                        })
                        ->orWhere('booking_extensions.is_item_returned', 1);
                });
                $responseKey = 'vendor_previous_bookings_is';
                break;

            default:
                return $this->addErrorResponse(500, trans('front.invalid_booking_type'), '');
        }

        $results = $bookings->orderByDesc('id')
            ->skip($offset)
            ->take($limit)
            ->get()
            ->map(fn($item) => $this->transformBooking($item, $upcomingType))
            ->filter()
            ->values();

        $nextOffset = $results->isEmpty() ? -1 : $offset + $results->count();

        return $this->addSuccessResponse(200, trans("global.$responseKey"), [
            'Bookings' => $results,
            'offset' => $nextOffset,
            'limit' => $limit,
        ]);
    }

