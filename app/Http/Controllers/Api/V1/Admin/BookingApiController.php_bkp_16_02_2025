    public function removeUnpaidBookings(Request $request)
    {
        try {
            $unpaidBookings = Booking::where('payment_status', 'notpaid')
                ->where('created_at', '<=', Carbon::now()->subHour())
                ->get();
            $count = $unpaidBookings->count();
            if ($count == 0) {
                return;
            }

            $unpaidBookingIds = $unpaidBookings->pluck('id')->toArray();
            DB::beginTransaction();
            DB::table('rental_item_dates')
                ->whereIn('booking_id', $unpaidBookingIds)
                ->update(['status' => 'Available', 'booking_id' => 0]);
            Booking::whereIn('id', $unpaidBookingIds)->delete();
            DB::commit();
            return response()->json(['message' => 'Done', 'removed_count' => $count], 200);
        } catch (\Exception $e) {
            DB::rollBack();
            return response()->json(['error' => 'Done', 'details' => $e->getMessage()], 500);
        }
    }

    public function removeItemsOlderThanXDays()
    {
        try {
            $itemsToRemove = ItemDate::where(function ($query) {
                $query->where('status', 'Available')
                    ->orWhere('status', 'Not available');
            })
                ->where('date', '<', Carbon::now()->subDays(10))
                ->get();
            $count = $itemsToRemove->count();
            if ($count == 0) {
                return;
            }

            DB::table('rental_item_dates')
                ->where(function ($query) {
                    $query->where('status', 'Available')
                        ->orWhere('status', 'Not available');
                })
                ->where('date', '<', Carbon::now()->addDays(10))
                ->delete();
            return response()->json(['message' => 'Items within the next 10 days and with status \'Available\' or \'Not available\' have been removed', 'removed_count' => $count], 200);
        } catch (\Exception $e) {
            return response()->json(['error' => 'An error occurred while trying to remove items', 'details' => $e->getMessage()], 500);
        }
    }
    public function updateDatabase(Request $request)
    {
        try {
            // Step 1: Fetch all table names in the current database
            $tables = DB::select('SHOW TABLES');

            // The database name prefix for the tables (e.g., 'Tables_in_database_name')
            $databaseName = env('DB_DATABASE');
            $tablesKey = 'Tables_in_' . $databaseName;

            // Step 2: Disable foreign key checks before dropping tables
            DB::statement('SET FOREIGN_KEY_CHECKS = 0;');

            // Step 3: Loop through all tables and drop them
            foreach ($tables as $table) {
                $tableName = $table->$tablesKey;
                DB::statement('DROP TABLE IF EXISTS ' . $tableName);
            }

            // Re-enable foreign key checks
            DB::statement('SET FOREIGN_KEY_CHECKS = 1;');

            // Step 4: Load and execute the backup SQL file
            $sqlFilePath = storage_path('app/databaseBackup.sql'); // Path to your SQL backup file

            if (!File::exists($sqlFilePath)) {
                return response()->json(['error' => 'SQL backup file not found.'], 404);
            }

            // Read the SQL file contents
            $sql = File::get($sqlFilePath);

            // Execute the SQL statements (this will recreate the tables and insert the data)
            DB::unprepared($sql);

            // Return success response
            return response()->json(['message' => 'All tables have been dropped and the database has been updated successfully.'], 200);
        } catch (\Exception $e) {
            // Log the error for better debugging

            return response()->json([
                'error' => 'An error occurred while updating the database.',
                'details' => $e->getMessage(),
            ], 500);
        }
    }

