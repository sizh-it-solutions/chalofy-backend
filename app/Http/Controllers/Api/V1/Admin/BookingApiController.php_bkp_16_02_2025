    /**
     * Check the availability of bookings for a item within a given date range.
     *
     * @param Request $request
     * @return \Illuminate\Http\Response
     */

    public function checkBookingAvailability(Request $request)
    {
        $validator = Validator::make($request->all(), [
            'item_id' => 'required|exists:rental_items,id',
            'check_in' => 'required|date_format:Y-m-d|after_or_equal:today',
            'check_out' => 'required|date_format:Y-m-d|after_or_equal:check_in',
            'start_time' => 'nullable|date_format:g:i A',
            'end_time' => 'nullable|date_format:g:i A',
        ]);

        if ($validator->fails()) {
            return $this->errorComputing($validator);
        }

        try {
            $itemId = $request->input('item_id');
            $checkInDate = $request->input('check_in');
            $checkOutDate = $request->input('check_out');

            $startTime = $request->input('start_time');
            $endTime = $request->input('end_time');


            $startDatetime = $startTime
                ? Carbon::createFromFormat('Y-m-d g:i A', $checkInDate . ' ' . trim($startTime))
                : Carbon::parse($checkInDate)->startOfDay();

            $endDatetime = $endTime
                ? Carbon::createFromFormat('Y-m-d g:i A', $checkOutDate . ' ' . trim($endTime))
                : Carbon::parse($checkOutDate)->endOfDay();
            $calculatedEndTime = "11:45 PM";
            $blockedDates = ItemDate::where('item_id', $itemId)
                ->whereBetween('date', [$checkInDate, $checkOutDate])
                ->where('status', 'not Available')
                ->pluck('date')
                ->toArray();
            if (!empty($blockedDates)) {
                return $this->addErrorResponse(422, trans('front.dates_are_not_available'), [
                    'blocked_dates' => $blockedDates
                ]);
            }
            $existingBookings = Booking::where('itemid', $itemId)
                ->whereIn('status', ['Pending', 'Confirmed', 'Completed', 'PaymentFailed', 'Live'])
                ->where(function ($q) use ($startDatetime, $endDatetime) {
                    $q->whereBetween('check_in', [$startDatetime, $endDatetime])
                        ->orWhereBetween('check_out', [$startDatetime, $endDatetime])
                        ->orWhere(function ($q2) use ($startDatetime, $endDatetime) {
                            $q2->where('check_in', '<', $startDatetime)
                                ->where('check_out', '>', $endDatetime);
                        });
                })
                ->orderBy('check_in', 'asc')
                ->get();
            $lastBooking = Booking::where('itemid', $itemId)
                ->whereDate('check_out', '<=', $checkOutDate)
                ->whereIn('status', ['Pending', 'Confirmed', 'Completed', 'PaymentFailed', 'Live'])
                ->orderBy('check_out', 'desc')
                ->first();

            if (
                $lastBooking &&
                Carbon::parse($lastBooking->check_out)->toDateString() === Carbon::parse($checkInDate)->toDateString()
            ) {
                $nextStartTime = $lastBooking && $lastBooking->end_time
                    ? Carbon::parse($lastBooking->end_time)->format('g:i A')
                    : '7:00 AM';
            } else {
                $nextStartTime = '7:00 AM';
            }


            if ($existingBookings->isNotEmpty()) {
                $bookingSummary = [];
                foreach ($existingBookings as $booking) {
                    $bookingSummary[] = [
                        'date' => Carbon::parse($booking->check_in)->toDateString() . " --- " . Carbon::parse($booking->check_out)->toDateString(),
                        'start_time' => $booking->start_time ? Carbon::parse($booking->start_time)->format('g:i A') : 'N/A',
                        'end_time' => $booking->end_time ? Carbon::parse($booking->end_time)->format('g:i A') : 'N/A',
                    ];
                }


                return $this->addSuccessResponse(422, 'The selected dates have existing bookings.', [
                    'bookingOverlapDetails' => $bookingSummary,
                    'next_available_time_on_checkout' => $nextStartTime,
                    'next_start_time' => $nextStartTime,
                    'next_end_time' => $calculatedEndTime,
                ]);
            }
            $responseData = [
                'item_id' => $itemId,
                'check_in' => $startDatetime->format('Y-m-d'),
                'check_out' => $endDatetime->format('Y-m-d'),
                'next_start_time' => $nextStartTime,
                'next_end_time' => $calculatedEndTime,
                'is_available' => true,
            ];

            return $this->addSuccessResponse(200, trans('front.Result_found'), [
                'availability' => $responseData
            ]);

        } catch (\Exception $e) {
            return $this->addErrorResponse(500, trans('front.ServerError_internal_server_error'), $e->getMessage());
        }
    }



    public function checkBookingAvailability_bk(Request $request)
    {

        $validator = Validator::make($request->all(), [
            'item_id' => 'required|exists:rental_items,id',
            'check_in' => 'required|date_format:Y-m-d|after_or_equal:today',
            'check_out' => 'required|date_format:Y-m-d',
        ]);
        $allowedModules = $this->sameDayBookingModule();

        $validator->sometimes('check_out', 'after:check_in', function ($input) use ($request, $allowedModules) {
            return !in_array($request->input('module_id'), $allowedModules);
        });

        if ($validator->fails()) {
            return $this->errorComputing($validator);
        }

        // try {
        $ItemId = $request->input('item_id');
        $checkInDate = $request->input('check_in');
        $checkOutDate = $request->input('check_out');
        $module = $this->getModuleIdOrDefault($request);
        $start_time = $request->input('start_time', null);
        $end_time = $request->input('end_time', null);
        $checkOutDateReturn = $checkOutDate;
        $checkOutDate = $this->returncheckOutDateByModule($checkInDate, $start_time, $checkOutDate, $end_time, $module);

        // Find the item by ID
        $item = Item::findOrFail($ItemId);
        $lastBooking = Booking::where('itemid', $ItemId)
            ->where('check_out', '<=', $checkInDate)
            ->whereIn('status', ['Pending', 'Confirmed', 'Completed'])
            ->orderBy('check_out', 'desc')
            ->first();

        $overlappingBookings = Booking::where('itemid', $ItemId)
            ->where('check_in', '<', $checkOutDate)
            ->where('check_out', '>', $checkInDate)
            ->whereIn('status', ['Pending', 'Confirmed', 'Completed'])
            ->get();

        $isAvailable = $overlappingBookings->isEmpty();
        if ($overlappingBookings->isNotEmpty()) {
            $bookingSummary = [];
            foreach ($overlappingBookings as $booking) {
                $date = $booking->check_in;
                $startTime = Carbon::parse($booking->start_time)->format('H:i');
                $endTime = Carbon::parse($booking->end_time)->format('H:i');

                if (!isset($bookingSummary[$date])) {
                    $bookingSummary[$date] = [
                        'date' => $date,
                        'start_time' => $startTime,
                        'end_time' => $endTime,
                    ];
                } else {
                    $bookingSummary[$date]['start_time'] = min($bookingSummary[$date]['start_time'], $startTime);
                    $bookingSummary[$date]['end_time'] = max($bookingSummary[$date]['end_time'], $endTime);
                }
            }

            foreach ($bookingSummary as &$summary) {
                $summary['start_time'] = Carbon::createFromFormat('H:i', $summary['start_time'])->format('g:i A');
                $summary['end_time'] = Carbon::createFromFormat('H:i', $summary['end_time'])->format('g:i A');
            }
            $flatBookingSummary = array_values($bookingSummary);
            return $this->addSuccessResponse(422, 'dates overlap with existing bookings', ['bookingOverlapDetails' => $flatBookingSummary]);
        }

        $getMissingDaya = $this->getMissingDays($ItemId); // It's for office module
        if ($isAvailable) {
            $dates = [];
            $currentDate = Carbon::parse($checkInDate);
            $endDate = Carbon::parse($checkOutDate);
            $allDaysMatch = true;

            while ($currentDate < $endDate) {
                $dates[] = $currentDate->toDateString();
                $currentDate->addDay(); // Increment by one day

                $dayOfWeek = $currentDate->format('l'); // Get the day of the week (e.g., Monday, Tuesday, etc.)
                if (in_array($dayOfWeek, $getMissingDaya)) {
                    $allDaysMatch = false;
                    break;
                }
            }

            if (!$allDaysMatch) {
                return $this->addErrorResponse(422, trans('front.dates_are_not_available'), '');
            }

            $ItemDates = ItemDate::where('item_id', $ItemId)
                ->whereIn('date', $dates)
                ->where('status', 'not Available')
                ->get();

            if (count($ItemDates) > 1) {
                return $this->addErrorResponse(422, trans('front.dates_are_not_available'), '');
            }

            $force = true;

            if ($ItemDates->where('status', trans('front.not_available'))->count() > 0) {
                $isAvailable = false;
            } else {
                $isAvailable = true;
            }
            $nextStartTime = '12:00 AM';
        } else {
            return $this->addErrorResponse(422, 'The selected dates overlap with an existing booking', '');
        }

        if ($lastBooking && Carbon::parse($lastBooking->check_out)->equalTo(Carbon::parse($checkInDate))) {

            $nextStartTime = $lastBooking->end_time;
        }

        // Prepare the response data
        $responseData = [
            'item_id' => $ItemId,
            'check_in' => $checkInDate,
            'check_out' => $checkOutDateReturn,
            'next_start_time' => $nextStartTime,
            'is_available' => $isAvailable,
        ];

        if ($isAvailable) {
            return $this->addSuccessResponse(200, trans('front.Result_found'), ['availability' => $responseData]);
        } else {
            return $this->addErrorResponse(500, trans('front.dates_are_not_available'), '');
        }
        try {
        } catch (\Exception $e) {
            return $this->addErrorResponse(500, trans('front.ServerError_internal_server_error'), $e->getMessage());
        }
    }

