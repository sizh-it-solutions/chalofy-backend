            ]);

            if ($validator->fails()) {
                return $this->errorComputing($validator);
            }

            $limit = $request->input('limit', 10);
            $offset = $request->input('offset', 0);

            $user_id = $this->checkUserByToken($request->token);
            if (!$user_id) {
                return $this->addErrorResponse(419, trans('front.token_not_match'), '');
            }

            $module = $this->getModuleIdOrDefault($request);
            $upcomingType = $request->type;
            $today = Carbon::now()->format('Y-m-d');
            $currentTime = Carbon::now()->format('H:i:s');

            $bookingsQuery = Booking::where('userid', $user_id)
                ->whereIn('payment_status', ['paid'])
                ->where('module', $module)
                ->with(['extension', 'host'])
                ->leftJoin('booking_extensions', 'bookings.id', '=', 'booking_extensions.booking_id')
                ->leftJoin('booking_finance', 'bookings.id', '=', 'booking_finance.booking_id')
                ->select(
                    'bookings.*',
                    'booking_extensions.is_item_delivered',
                    'booking_extensions.is_item_received',
                    'booking_extensions.is_item_returned',
                    'booking_extensions.doorStep_address',
                    'booking_finance.total_day',
                    'booking_finance.per_day',
                    'booking_finance.base_price',
                    'booking_finance.doorstep_price',
                    'booking_finance.security_money',
                    'booking_finance.iva_tax',
                    'booking_finance.coupon_code',
                    'booking_finance.coupon_discount',
                    'booking_finance.discount_price',
                    'booking_finance.cancelled_charge'
                );

            $statusFilter = [
                'upcoming' => function ($query) use ($today) {
                    $query->where('check_in', '>=', $today)
                        ->whereNotIn('bookings.status', ['Cancelled', 'Declined', 'Completed'])
                        ->where(function ($subQuery) {
                            $subQuery->whereNull('booking_extensions.is_item_received')
                                ->orWhere('booking_extensions.is_item_received', '!=', 1);
                        });
                },
                'ongoing' => function ($query) {
                    $query->whereIn('bookings.status', ['Live'])
                        ->where('booking_extensions.is_item_received', 1);
                },
                'Cancelled' => function ($query) use ($today) {
                    $query->where('check_in', '>', $today)
                        ->whereIn('bookings.status', ['Cancelled', 'Declined']);
                },
                'previous' => function ($query) use ($today, $currentTime) {
                    $query->where(function ($q) use ($today, $currentTime) {
                        $q->where('check_out', '<', $today)
                            ->orWhere(function ($sub) use ($today, $currentTime) {
                                $sub->where('check_out', '=', $today)
                                    ->whereRaw("STR_TO_DATE(end_time, '%H:%i:%s') <= ?", [$currentTime]);
                            })
                            ->orWhere('booking_extensions.is_item_returned', 1);
                    });
                }
            ];

            if (!isset($statusFilter[$upcomingType])) {
                return $this->addErrorResponse(400, trans('front.invalid_booking_type'), '');
            }

            $bookings = $bookingsQuery
                ->where($statusFilter[$upcomingType])
                ->orderByDesc('id')
                ->skip($offset)
                ->take($limit)
                ->get()
                ->map(function ($booking) use ($today, $currentTime, $upcomingType) {

                    // Handle reviews
                    $review = Review::where('bookingid', $booking->id)->where('guest_rating', '>', 0)->first();
                    $booking['review_status'] = $review ? '1' : '0';
                    $booking['review_rating'] = $review->guest_rating ?? '';
                    $booking['review'] = $review->guest_message ?? '';

                    // Host data
                    if ($booking->host) {
                        $booking['host_name'] = $booking->host->first_name . ' ' . $booking->host->last_name;
                        $booking['host_number'] = $booking->host->phone;
                        $booking['host_email'] = $booking->host->email;
                        $booking['host_phone_country'] = $booking->host->phone_country;
                    }

                    // Item data
                    $itemData = json_decode($booking->item_data, true);
                    $booking['item_title'] = $itemData[0]['name'] ?? ($booking->item_title ?? '');
                    $booking['total_day'] = $booking->total_day;
                    $booking['per_day'] = $booking->per_day;
                    $booking['payment_method'] = $booking->payment_method === 'offline' ? 'Cash' : $booking->payment_method;
                    $booking['booking_meta'] = json_encode(['start_time' => '17:30 PM', 'end_time' => '10:30 PM']);


                    $booking['per_day'] = formatCurrency($booking->per_day ?? 0);
                    $booking['base_price'] = formatCurrency($booking->base_price ?? 0);
                    $booking['doorstep_price'] = formatCurrency($booking->doorstep_price ?? 0);
                    $booking['security_money'] = formatCurrency($booking->security_money ?? 0);
                    $booking['iva_tax'] = formatCurrency($booking->iva_tax ?? 0);
                    $booking['coupon_discount'] = formatCurrency($booking->coupon_discount ?? 0);
                    $booking['discount_price'] = formatCurrency($booking->discount_price ?? 0);
                    $booking['cancelled_charge'] = formatCurrency($booking->cancelled_charge ?? 0);
                    $booking['total'] = formatCurrency($booking->total ?? 0);
                    $booking['amount_to_pay'] = formatCurrency($booking->amount_to_pay ?? 0);

                    if ($booking->extension) {
                        $booking['doorStep_price'] = formatCurrency($booking->extension->doorStep_price ?? 0);

                        if ($upcomingType === 'upcoming') {
                            $isItemReceived = $booking->extension->is_item_received;
                            $isItemDelivered = $booking->extension->is_item_delivered;

                            $checkInDate = Carbon::createFromFormat('d-m-Y h:i A', $booking->check_in)->toDateString();
                            $todayDate = DateFormat::toDateString(Carbon::now());

                            $booking['is_received_button'] = ($checkInDate === $todayDate && $isItemReceived == 0 && $isItemDelivered == 1) ? 'yes' : 'no';

                        }

                        if ($upcomingType === 'previous') {
                            if ($booking->extension->is_item_received == 1 && $booking->extension->is_item_returned != 1) {
                                return null; // skip if item received but not returned
                            }
                            $booking['is_received_button'] = ($booking->extension->is_item_received == 0) ? 'yes' : 'no';
                        }
                    }

                    unset($booking->extension, $booking->host);
                    return $booking;
                })->filter()->values();

            $nextOffset = $bookings->isEmpty() ? -1 : ($offset + $bookings->count());

            $responseData = [
                'Bookings' => $bookings,
                'offset' => $nextOffset,
                'limit' => $limit,
            ];

            $successMessage = match ($upcomingType) {
                'upcoming' => trans('front.upcoming_bookings_is'),
                'ongoing' => trans('front.ongoing_bookings_is'),
                'previous' => trans('front.previous_bookings_is'),
                default => trans('front.bookings_fetched'),
            };

            return $this->addSuccessResponse(200, $successMessage, $responseData);

        } catch (\Exception $e) {
            return $this->addErrorResponse(500, trans('front.ServerError_internal_server_error'), $e->getMessage());
        }
    }

