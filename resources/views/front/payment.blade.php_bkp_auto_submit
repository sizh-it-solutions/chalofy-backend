  <!-- JavaScript for the loader and Stripe integration -->
  <script>
  document.addEventListener("DOMContentLoaded", function () {
    const delay = 2000; // Delay before auto-submit (4 seconds)
    const loader = document.querySelector('.loader-overlay');
    if (loader) loader.style.display = 'flex';

    // Try to find the first payment form
    const paymentForm = document.querySelector(".payment-form");
    const paymentLink = document.querySelector(".payment-item a");

    // Helper to show a message in loader
    function showLoaderMessage(text) {
      if (loader) {
        loader.style.display = 'flex';
        loader.querySelector('.loader-text').textContent = text;
      }
    }

    if (paymentForm) {
      // Detect which payment method it is
      const methodName = paymentForm.querySelector(".payment-method-name")?.textContent || "your payment provider";
      showLoaderMessage(`We are redirecting to ${methodName}...`);

      setTimeout(() => {
        showLoaderMessage(`Connecting securely to ${methodName}...`);
        paymentForm.submit();
      }, delay);

    } else if (paymentLink) {
      const methodName = paymentLink.querySelector(".payment-method-name")?.textContent || "your payment provider";
      showLoaderMessage(`We are redirecting to ${methodName}...`);

      setTimeout(() => {
        showLoaderMessage(`Opening ${methodName}...`);
        window.location.href = paymentLink.href;
      }, delay);
    }
  });
</script>






